<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:SimPe"
        xmlns:avaloniaHex="clr-namespace:AvaloniaHex;assembly=AvaloniaHex"
        xmlns:rendering="clr-namespace:AvaloniaHex.Rendering;assembly=AvaloniaHex"
        x:Class="SimPe.MainForm"
        Title="SimPE - Sims Package Editor"
        Width="1200" Height="800"
        MinWidth="800" MinHeight="600">

    <DockPanel>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- Menu bar                                                    -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_New"            x:Name="MenuFileNew"/>
                <MenuItem Header="_Open..."         x:Name="MenuFileOpen"/>
                <MenuItem Header="_Close"          x:Name="MenuFileClose"/>
                <MenuItem Header="_Save"            x:Name="MenuFileSave"/>
                <MenuItem Header="Save _As..."      x:Name="MenuFileSaveAs"/>
                <Separator/>
                <MenuItem Header="_Recent Files"    x:Name="MenuFileRecent"/>
                <Separator/>
                <MenuItem Header="E_xit"            x:Name="MenuFileExit"/>
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="_Undo"            x:Name="MenuEditUndo"/>
                <MenuItem Header="_Redo"            x:Name="MenuEditRedo"/>
            </MenuItem>
            <MenuItem Header="_Package">
                <MenuItem Header="_Properties..."   x:Name="MenuPackageProps"/>
            </MenuItem>
            <MenuItem Header="_Resource">
                <MenuItem Header="_Add..."          x:Name="MenuResourceAdd"/>
                <MenuItem Header="_Delete"          x:Name="MenuResourceDelete"/>
                <Separator/>
                <MenuItem Header="_Export..."       x:Name="MenuResourceExport"/>
                <MenuItem Header="_Import..."       x:Name="MenuResourceImport"/>
                <MenuItem Header="_Replace..."      x:Name="MenuResourceReplace"/>
                <Separator/>
                <MenuItem Header="C_lone..."        x:Name="MenuResourceClone"/>
            </MenuItem>
            <MenuItem Header="_Tools"               x:Name="MenuTools"/>
            <MenuItem Header="E_xtra"               x:Name="MenuExtra"/>
            <MenuItem Header="_Help">
                <MenuItem Header="_About SimPE"     x:Name="MenuHelpAbout"/>
            </MenuItem>
        </Menu>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- Status bar                                                  -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <Border DockPanel.Dock="Bottom"
                Background="#F0F0F0"
                BorderBrush="#CCCCCC"
                BorderThickness="0,1,0,0"
                Height="22">
            <TextBlock x:Name="StatusText"
                       Text="Ready"
                       VerticalAlignment="Center"
                       Margin="6,0"/>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- Main content — vertical split: upper panel / lower panel   -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <Grid>
            <Grid.RowDefinitions>
                <!-- Upper panel: resource tree, list, actions -->
                <RowDefinition Height="3*" MinHeight="120"/>
                <!-- Horizontal drag handle -->
                <RowDefinition Height="5"/>
                <!-- Lower panel: plugin / wrapper editor -->
                <RowDefinition Height="2*" MinHeight="80"/>
            </Grid.RowDefinitions>

            <!-- ─────────────────────────────────────────────────────── -->
            <!-- Upper panel — three columns with two drag handles       -->
            <!-- ─────────────────────────────────────────────────────── -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <!-- Resource Tree -->
                    <ColumnDefinition Width="200" MinWidth="80"/>
                    <!-- Vertical drag handle -->
                    <ColumnDefinition Width="5"/>
                    <!-- Resource List (expands) -->
                    <ColumnDefinition Width="*"   MinWidth="200"/>
                    <!-- Vertical drag handle -->
                    <ColumnDefinition Width="5"/>
                    <!-- Actions / Filter -->
                    <ColumnDefinition Width="220" MinWidth="120"/>
                </Grid.ColumnDefinitions>

                <!-- Resource Tree -->
                <Border Grid.Column="0"
                        BorderBrush="#DCDCDC"
                        BorderThickness="0,0,0,0">
                    <DockPanel>
                        <Border DockPanel.Dock="Top"
                                Background="#E4E4E4"
                                Padding="6,3">
                            <TextBlock Text="Resource Tree"
                                       FontWeight="SemiBold"
                                       FontSize="11"/>
                        </Border>
                        <TreeView x:Name="ResourceTree">
                            <TreeView.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayName}" FontSize="11"/>
                                </DataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </DockPanel>
                </Border>

                <GridSplitter Grid.Column="1"
                              ResizeDirection="Columns"
                              Background="#CCCCCC"
                              HorizontalAlignment="Stretch"/>

                <!-- Resource List -->
                <Border Grid.Column="2" Background="White">
                    <DockPanel>
                        <Border DockPanel.Dock="Top"
                                Background="#E4E4E4"
                                Padding="6,3">
                            <TextBlock Text="Resource List"
                                       FontWeight="SemiBold"
                                       FontSize="11"/>
                        </Border>
                        <DataGrid x:Name="ResourceList"
                                  AutoGenerateColumns="False"
                                  CanUserReorderColumns="False"
                                  CanUserResizeColumns="True"
                                  GridLinesVisibility="Horizontal"
                                  IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name"        Width="*"   Binding="{Binding Name}"/>
                                <DataGridTextColumn Header="Type"        Width="72"  Binding="{Binding Type}"/>
                                <DataGridTextColumn Header="Group"       Width="88"  Binding="{Binding Group}"/>
                                <DataGridTextColumn Header="Instance Hi" Width="88"  Binding="{Binding InstanceHi}"/>
                                <DataGridTextColumn Header="Instance"    Width="88"  Binding="{Binding Instance}"/>
                                <DataGridTextColumn Header="Offset"      Width="78"  Binding="{Binding Offset}"/>
                                <DataGridTextColumn Header="Size"        Width="68"  Binding="{Binding Size}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>

                <GridSplitter Grid.Column="3"
                              ResizeDirection="Columns"
                              Background="#CCCCCC"
                              HorizontalAlignment="Stretch"/>

                <!-- Right panel: Resource Actions, Filter Resources, Object Workshop -->
                <TabControl Grid.Column="4" Background="#FAFAFA" TabStripPlacement="Right">
                    <TabItem Header="Resource Actions">
                        <ScrollViewer>
                            <StackPanel x:Name="ActionPanel" Margin="4" Spacing="4"/>
                        </ScrollViewer>
                    </TabItem>
                    <TabItem Header="Filter Resources">
                        <StackPanel x:Name="FilterPanel" Margin="8" Spacing="6">
                            <TextBlock Text="Group:" FontSize="11"/>
                            <TextBox x:Name="FilterGroup"/>
                            <TextBlock Text="Instance:" FontSize="11"/>
                            <TextBox x:Name="FilterInstance"/>
                            <TextBlock Text="Type / RCOL Name:" FontSize="11"/>
                            <TextBox x:Name="FilterType"/>
                            <Button x:Name="BtnApplyFilter" Content="Apply Filter" Margin="0,6,0,0"/>
                        </StackPanel>
                    </TabItem>
                    <TabItem Header="Object Workshop">
                        <!-- OW panel loaded here at runtime; future: Dock.Avalonia host -->
                        <ContentControl x:Name="ObjectWorkshopPanel"/>
                    </TabItem>
                </TabControl>

            </Grid>

            <!-- Horizontal drag handle (upper / lower) -->
            <GridSplitter Grid.Row="1"
                          ResizeDirection="Rows"
                          HorizontalAlignment="Stretch"
                          Background="#CCCCCC"/>

            <!-- ─────────────────────────────────────────────────────── -->
            <!-- Lower panel — tabbed: Resource Info / Hex / Converter / Plugin -->
            <!-- ─────────────────────────────────────────────────────── -->
            <TabControl Grid.Row="2" x:Name="LowerTabs" Background="#FAFAFA" TabStripPlacement="Bottom">

                <!-- Resource Info tab -->
                <TabItem Header="Resource Info">
                    <local:ResourceInfoPanel x:Name="ResInfoPanel"/>
                </TabItem>

                <!-- Hex View tab -->
                <TabItem Header="Hex View">
                    <avaloniaHex:HexEditor x:Name="HexEditor"
                                           FontFamily="Cascadia Code,JetBrains Mono,Monospace,monospace"
                                           FontSize="12">
                        <avaloniaHex:HexEditor.Columns>
                            <rendering:OffsetColumn />
                            <rendering:HexColumn />
                            <rendering:AsciiColumn />
                        </avaloniaHex:HexEditor.Columns>
                    </avaloniaHex:HexEditor>
                </TabItem>

                <!-- Converter tab -->
                <TabItem Header="Converter">
                    <ScrollViewer>
                        <Grid ColumnDefinitions="80,8,160,16,80,8,160"
                              RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                              Margin="12,10">

                            <!-- Left column -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Offset"  FontWeight="SemiBold" FontSize="11" VerticalAlignment="Center" Margin="0,3"/>
                            <TextBox   Grid.Row="0" Grid.Column="2" x:Name="CvOffset" IsReadOnly="True" FontFamily="Monospace" FontSize="11" Margin="0,2"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Byte"    FontWeight="SemiBold" FontSize="11" VerticalAlignment="Center" Margin="0,3"/>
                            <TextBox   Grid.Row="1" Grid.Column="2" x:Name="CvByte"   IsReadOnly="True" FontFamily="Monospace" FontSize="11" Margin="0,2"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="UShort"  FontWeight="SemiBold" FontSize="11" VerticalAlignment="Center" Margin="0,3"/>
                            <TextBox   Grid.Row="2" Grid.Column="2" x:Name="CvUShort" IsReadOnly="True" FontFamily="Monospace" FontSize="11" Margin="0,2"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="UInt"    FontWeight="SemiBold" FontSize="11" VerticalAlignment="Center" Margin="0,3"/>
                            <TextBox   Grid.Row="3" Grid.Column="2" x:Name="CvUInt"   IsReadOnly="True" FontFamily="Monospace" FontSize="11" Margin="0,2"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="ULong"   FontWeight="SemiBold" FontSize="11" VerticalAlignment="Center" Margin="0,3"/>
                            <TextBox   Grid.Row="4" Grid.Column="2" x:Name="CvULong"  IsReadOnly="True" FontFamily="Monospace" FontSize="11" Margin="0,2"/>

                            <!-- Right column -->
                            <TextBlock Grid.Row="0" Grid.Column="4" Text="Float"   FontWeight="SemiBold" FontSize="11" VerticalAlignment="Center" Margin="0,3"/>
                            <TextBox   Grid.Row="0" Grid.Column="6" x:Name="CvFloat"  IsReadOnly="True" FontFamily="Monospace" FontSize="11" Margin="0,2"/>

                            <TextBlock Grid.Row="1" Grid.Column="4" Text="Double"  FontWeight="SemiBold" FontSize="11" VerticalAlignment="Center" Margin="0,3"/>
                            <TextBox   Grid.Row="1" Grid.Column="6" x:Name="CvDouble" IsReadOnly="True" FontFamily="Monospace" FontSize="11" Margin="0,2"/>

                            <TextBlock Grid.Row="2" Grid.Column="4" Text="Short"   FontWeight="SemiBold" FontSize="11" VerticalAlignment="Center" Margin="0,3"/>
                            <TextBox   Grid.Row="2" Grid.Column="6" x:Name="CvShort"  IsReadOnly="True" FontFamily="Monospace" FontSize="11" Margin="0,2"/>

                            <TextBlock Grid.Row="3" Grid.Column="4" Text="Int"     FontWeight="SemiBold" FontSize="11" VerticalAlignment="Center" Margin="0,3"/>
                            <TextBox   Grid.Row="3" Grid.Column="6" x:Name="CvInt"    IsReadOnly="True" FontFamily="Monospace" FontSize="11" Margin="0,2"/>

                            <TextBlock Grid.Row="4" Grid.Column="4" Text="Bits"    FontWeight="SemiBold" FontSize="11" VerticalAlignment="Center" Margin="0,3"/>
                            <TextBox   Grid.Row="4" Grid.Column="6" x:Name="CvBits"   IsReadOnly="True" FontFamily="Monospace" FontSize="11" Margin="0,2"/>

                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <!-- Plugin tab — plugin-specific editor UI loads here -->
                <TabItem Header="Plugin">
                    <ContentControl x:Name="PluginPanel"/>
                </TabItem>

            </TabControl>

        </Grid>
    </DockPanel>
</Window>
